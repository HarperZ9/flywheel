# --- secrets / env (NEVER commit) ---
.env
.env.*
*.key
*.pem
*.token
CLAUDE.local.md

# --- python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# --- ephemeral harness output (regenerated by tests / runs) ---
envelopes-turn-*/
.warden-safe-cache/
*.safe

# --- proprietary corpus source identifiers ---
