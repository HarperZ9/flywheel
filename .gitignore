# --- secrets / env (NEVER commit) ---
.env
.env.*
*.key
*.pem
*.token
CLAUDE.local.md

# --- python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# --- ephemeral harness output (regenerated by tests / runs) ---
envelopes-turn-*/
.warden-safe-cache/
*.safe

# --- proprietary corpus source identifiers ---
# INVARIANT: only aggregate stats leave the repo; the per-file source manifest
# enumerates real C:\dev source paths and must stay proprietary.
dataset/manifest.jsonl

# --- large run assets: these live on E:\local-model-run, never in the repo ---
*.safetensors
*.gguf
*.bin
*.pt
*.pth
checkpoints/
models/
data/packed/

# --- os / editor noise ---
.DS_Store
Thumbs.db
*.swp
.m7-run/
artifacts/exe/
.pyinstaller/
*.spec

# --- benchmark/screen scratch (never commit) ---
.screen-run/

# --- machine-local run root (keeps absolute paths out of shipped source) ---
# One line naming this machine's training/run root (e.g. E:/local-model-run).
# Read by harness/run_paths.py; never shipped, so the source stays path-clean.
.flywheel-run-root
