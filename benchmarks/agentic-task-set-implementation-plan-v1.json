  "tests_first_plan": [
    {
      "test_name": "test_manifest_expands_all_task_rows_without_execution",
      "assertions": [
        "schema is harness.agentic-task-manifest/v1",
        "task_count equals task-set task length",
        "every task id appears exactly once as a coverage unit",
        "no provider execution fields claim live execution"
      ]
    },
    {
      "test_name": "test_manifest_maps_tasks_to_benchmark_ids_from_adapter",
      "assertions": [
        "agt-002-forum-deep-verify-scale maps to forum_ledger_deep_verify_scaling",
        "agt-003-codex-flywheel-shared-task maps to cross_harness_reproducibility_matrix",
        "agt-004-local-14b-endpoint-gate maps to local_resource_pressure_14b_32b"
      ]
    },
    {
      "test_name": "test_manifest_rejects_missing_required_task_fields",
      "assertions": [
        "missing task id fails",
        "missing lane fails",
        "missing expected_artifacts fails"
      ]
    },
    {
      "test_name": "test_benchmark_coverage_recognizes_agentic_task_scorecard_schema",
