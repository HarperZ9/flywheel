        "harness.agentic-task-scorecard/v1 maps rows to benchmark ids",
        "task_id becomes coverage_unit",
        "provider_role participates in provider-by-unit coverage"
      ]
    },
    {
      "test_name": "test_closed_loop_seed_includes_agentic_task_manifest_preflight",
      "assertions": [
        "agentic_task_manifest appears after benchmark_profile and before coverage",
        "skip flag removes the step",
        "step expected artifacts include agentic_task_manifest.json and agentic_task_manifest.md"
      ]
    },
    {
      "test_name": "test_outcome_summarizes_manifest_as_planned_not_executed",
      "assertions": [
        "manifest-only artifacts do not count as benchmark scorecards",
        "outcome reports task_count and planned coverage units",
        "outcome states no provider results exist"
      ]
    }
  ],
